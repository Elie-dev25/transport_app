# Configuration des notifications email pour TransportUdM
# Copiez ce fichier vers .env et remplissez les valeurs

# Configuration SMTP pour Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=elienjine15@gmail.com
SMTP_PASSWORD=votre_mot_de_passe_application_gmail
SMTP_USE_TLS=true
SMTP_USE_SSL=false
MAIL_FROM=elienjine15@gmail.com

# Activation des notifications
ENABLE_EMAIL_NOTIFICATIONS=true

# Configuration de base de données (OBLIGATOIRE en production)
# Format: mysql+pymysql://utilisateur:mot_de_passe@host:port/nom_base
DATABASE_URL=mysql+pymysql://transport_user:VOTRE_MOT_DE_PASSE_SECURISE@localhost:3306/transport_udm

# Base de données de développement (optionnel, utilise DATABASE_URL par défaut)
# DEV_DATABASE_URL=mysql+pymysql://dev_user:dev_password@localhost:3306/transport_udm_dev

# Clé secrète pour la production (OBLIGATOIRE en production)
# Générer avec: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGEZ_MOI_AVEC_UNE_CLE_ALEATOIRE_DE_64_CARACTERES

# Environnement
FLASK_ENV=development

# Configuration LDAP (OBLIGATOIRE si authentification LDAP activée)
LDAP_SERVER=192.168.21.131
LDAP_DOMAIN=domaine.local
BASE_DN=DC=domaine,DC=local

# Instructions pour Gmail:
# 1. Activez l'authentification à 2 facteurs sur votre compte Gmail
# 2. Allez dans Paramètres Google > Sécurité > Mots de passe d'application
# 3. Générez un nouveau mot de passe d'application pour "TransportUdM"
# 4. Utilisez ce mot de passe d'application (16 caractères) dans SMTP_PASSWORD
# 5. Ne jamais utiliser votre mot de passe Gmail principal

# Pour tester la configuration:
# python test_notifications.py config
